# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Website/link reader backend keys.
# Browserless is tried first for full page reading.
BROWSERLESS_TOKEN="YOUR_BROWSERLESS_TOKEN"
BROWSERLESS_URL="https://chrome.browserless.io/content"

# Firecrawl is used for scrape/search fallback.
FIRECRAWL_API_KEY="YOUR_FIRECRAWL_API_KEY"

METALS_API_KEY="YOUR_METALS_API_KEY"
METALS_DEV_API_KEY="YOUR_METALS_DEV_API_KEY"
API_NINJAS_API_KEY="YOUR_API_NINJAS_API_KEY"
