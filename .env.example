# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Microsoft Azure settings for Outlook / Hotmail integration
MICROSOFT_CLIENT_ID=YOUR_MICROSOFT_CLIENT_ID
MICROSOFT_SIGNATURE_HASH=YOUR_BASE64_SIGNATURE_HASH

# Appwrite Cloud Memory settings
# Keep APPWRITE_MEMORY_ENABLED=false until the Appwrite database and collection are ready.
APPWRITE_MEMORY_ENABLED=false
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=YOUR_APPWRITE_PROJECT_ID
APPWRITE_DATABASE_ID=YOUR_APPWRITE_DATABASE_ID
APPWRITE_MEMORY_COLLECTION_ID=memories
